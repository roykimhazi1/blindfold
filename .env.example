# ── AI ─────────────────────────────────────────────────────────────
# Optional. When unset, the agent layer runs in deterministic mock mode.
ANTHROPIC_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────
# Project URL: https://xaeamdvhsemeynmmkexi.supabase.co
# Get the service role key from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xaeamdvhsemeynmmkexi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────
# Get API key: https://resend.com/api-keys
# Verify the sending domain (blindfold.travel) in Resend before going live.
RESEND_API_KEY=

# ── Providers (sandbox/live) ───────────────────────────────────────
# Leave blank / set to "mock" to use deterministic mock providers.
PROVIDER_MODE=mock        # mock | sandbox | live
DUFFEL_API_KEY=           # https://duffel.com — sandbox: starts with duffel_test_
HOTELBEDS_API_KEY=        # https://developer.hotelbeds.com
HOTELBEDS_SECRET=         # Hotelbeds HMAC secret (different from the API key)
