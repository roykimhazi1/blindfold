# ── AI ─────────────────────────────────────────────────────────────
# Optional. When unset, the agent layer runs in deterministic mock mode.
ANTHROPIC_API_KEY=

# ── Supabase (required) ───────────────────────────────────────────
# Persistence (bookings + secrets), Google auth, and realtime all run on
# Supabase. URL + anon/publishable key are public; the service-role key is
# server-only (booking writes + the sealed secret table). Set these in
# apps/web/.env.local for the web app.
# Project URL: https://xaeamdvhsemeynmmkexi.supabase.co
# Get the service role key from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xaeamdvhsemeynmmkexi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (Resend) ─────────────────────────────────────────────────
# Get API key: https://resend.com/api-keys
# Verify the sending domain (blindfold.travel) in Resend before going live.
RESEND_API_KEY=

# ── Providers (sandbox/live) ───────────────────────────────────────
# Leave blank / set to "mock" to use deterministic mock providers.
# One Duffel key covers both flights (offers) and hotels (Stays).
PROVIDER_MODE=mock        # mock | sandbox | live
DUFFEL_API_KEY=           # https://duffel.com — sandbox: starts with duffel_test_

# ── Ops desk (secrecy mode) ────────────────────────────────────────
# In "Full surprise" mode supplier (airline/hotel) emails go here instead of
# the traveller, so receipts can't spoil the destination. The phone number
# rides every supplier order (travellers' phones aren't collected).
OPS_CONTACT_EMAIL=
OPS_CONTACT_PHONE=        # E.164, e.g. +97233333333
